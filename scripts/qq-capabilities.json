    "unity.raw-tykit": {
      "engineAdapter": "unity",
      "transportAdapter": "http",
      "hostAdapters": ["claude", "codex", "cursor", "ci"],
      "official": true,
      "description": "Raw tykit HTTP or eval fallback when workflow wrappers are unavailable.",
      "capabilities": [
        "compile",
        "console.read",
        "console.clear",
        "scene.query",
        "scene.mutate",
        "asset.mutate"
      ],
      "toolMappings": {
