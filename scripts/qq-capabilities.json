{
  "schemaVersion": "1",
  "defaultEngine": "unity",
  "capabilities": {
    "compile": {
      "kind": "workflow",
      "description": "Compile project code or scripts and return a structured result."
    },
    "test": {
      "kind": "workflow",
      "description": "Run the default test workflow for the current engine."
    },
    "test.edit": {
      "kind": "workflow",
      "description": "Run editor-side or edit-mode style tests."
    },
    "test.play": {
      "kind": "workflow",
      "description": "Run runtime or play-mode style tests."
    },
    "console.read": {
      "kind": "io",
      "description": "Read engine or editor console output."
    },
    "console.clear": {
      "kind": "io",
      "description": "Clear engine or editor console output."
    },
    "artifact.scan": {
      "kind": "analysis",
      "description": "Scan project artifacts and derive normalized project facts."
    },
    "policy.check": {
      "kind": "analysis",
      "description": "Run deterministic policy checks and return structured findings."
    },
    "scene.query": {
      "kind": "query",
      "description": "Read scene or hierarchy state."
    },
    "scene.mutate": {
      "kind": "mutation",
      "description": "Mutate scene or hierarchy state."
    },
    "asset.query": {
      "kind": "query",
      "description": "Read asset metadata or inventory."
    },
    "asset.mutate": {
      "kind": "mutation",
      "description": "Create or mutate assets."
    },
    "input.simulate": {
      "kind": "mutation",
      "description": "Inject editor or runtime input through the engine bridge."
    },
    "ui.query": {
      "kind": "query",
      "description": "Read editor UI or authored UI asset state."
    },
    "ui.mutate": {
      "kind": "mutation",
      "description": "Create or mutate authored UI assets."
    },
    "animation.query": {
      "kind": "query",
      "description": "Read animation or sequencer asset state."
    },
    "animation.mutate": {
      "kind": "mutation",
      "description": "Create or mutate animation or sequencer assets."
    },
    "capture.screenshot": {
      "kind": "io",
      "description": "Capture a screenshot from the engine editor or runtime."
    }
  },
  "engineAdapters": {
    "unity": {
      "description": "Unity engine adapter. Current primary validation target."
    },
    "godot": {
      "description": "Godot engine adapter. First non-Unity runtime target."
    },
    "unreal": {
      "description": "Unreal engine adapter. Project-local direct path plus UnrealEditor command-line bridge."
    },
    "sbox": {
      "description": "S&box engine adapter. Project-local direct runtime plus built-in qq MCP bridge for editor/query/object/assets workflows."
    }
  },
  "hostAdapters": {
    "claude": {
      "description": "Claude Code skill and hook integration."
    },
    "codex": {
      "description": "Codex CLI / MCP integration."
    },
    "cursor": {
      "description": "Cursor or similar MCP-first editor integration."
    },
    "ci": {
      "description": "Non-interactive CI / pre-push execution."
    }
  },
  "transportAdapters": {
    "direct": {
      "description": "Project-local scripts and direct shell execution."
    },
    "mcp": {
      "description": "Model Context Protocol transport."
    },
    "http": {
      "description": "Direct HTTP engine bridge transport."
    }
  },
  "providers": {
    "unity.qq-direct": {
      "engineAdapter": "unity",
      "transportAdapter": "direct",
      "hostAdapters": ["claude", "codex", "ci"],
      "official": true,
      "description": "Project-local qq scripts with engine-aware direct fast paths for Unity.",
      "capabilities": [
        "compile",
        "test",
        "test.edit",
        "test.play",
        "artifact.scan",
        "policy.check"
      ],
      "toolMappings": {
        "compile": ["scripts/qq-compile.sh"],
        "test": ["scripts/qq-test.sh"],
        "artifact.scan": ["scripts/qq-project-state.py"],
        "policy.check": ["scripts/qq-policy-check.sh"]
      }
    },
    "unity.tykit-mcp": {
      "engineAdapter": "unity",
      "transportAdapter": "mcp",
      "hostAdapters": ["claude", "codex", "cursor"],
      "official": true,
      "description": "Built-in qq MCP bridge for typed Unity workflows, backed by tykit.",
      "capabilities": [
        "compile",
        "test",
        "console.read",
        "console.clear",
        "scene.query",
        "scene.mutate",
        "asset.query",
        "asset.mutate",
        "input.simulate",
        "ui.query",
        "ui.mutate",
        "animation.query",
        "animation.mutate",
        "capture.screenshot"
      ],
      "toolMappings": {
        "compile": ["unity_compile"],
        "test": ["unity_run_tests"],
        "console.read": ["unity_console"],
        "console.clear": ["unity_console"],
        "scene.query": ["unity_query"],
        "scene.mutate": ["unity_object", "unity_editor"],
        "asset.query": ["unity_query", "unity_assets"],
        "asset.mutate": ["unity_assets"],
        "input.simulate": ["unity_input"],
        "ui.query": ["unity_ui"],
        "ui.mutate": ["unity_ui"],
        "animation.query": ["unity_animation"],
        "animation.mutate": ["unity_animation"],
        "capture.screenshot": ["unity_screenshot"]
      }
    },
    "unity.mcp-unity": {
      "engineAdapter": "unity",
      "transportAdapter": "mcp",
      "hostAdapters": ["claude", "codex", "cursor"],
      "official": false,
      "description": "Third-party mcp-unity backend.",
      "capabilities": [
        "compile",
        "test",
        "console.read",
        "scene.query",
        "scene.mutate"
      ],
      "toolMappings": {
        "compile": ["recompile_scripts"],
        "test": ["run_tests"],
        "console.read": ["get_console_logs"]
      }
    },
    "unity.unity-mcp": {
